<file path="HelideckVer2/Services/AlarmEngine.cs">
using HelideckVer2.Models;
using System;
using System.Collections.Generic;

namespace HelideckVer2.Services
{
    public class AlarmEngine
    {
        private readonly List<Alarm> _alarms = new();

        public event Action<Alarm> AlarmRaised;
        public event Action<Alarm> AlarmCleared;
        public event Action<Alarm> AlarmAcked;

        public void Register(Alarm alarm)
        {
            _alarms.Add(alarm);
        }

        public void Evaluate()
        {
            foreach (var alarm in _alarms)
            {
                bool changed = alarm.Evaluate();
                if (!changed) continue;

                if (alarm.IsActive)
                    AlarmRaised?.Invoke(alarm);
                else
                    AlarmCleared?.Invoke(alarm);
            }
        }

        public void Ack(string alarmId)
        {
            var alarm = _alarms.Find(a => a.Id == alarmId);
            if (alarm == null) return;

            if (alarm.Ack())
                AlarmAcked?.Invoke(alarm);
        }

        public IEnumerable<Alarm> GetAll() => _alarms;
    }
}
</file>

<file path="HelideckVer2/Services/ComEngine.cs">
using System;
using System.IO.Ports;
using System.Timers;

namespace HelideckVer2.Services
{
    public class ComEngine
    {
        public event Action<string, string> OnDataReceived;
        private System.Timers.Timer _simTimer;
        private double _angle = 0;
        private Random _random = new Random();

        public void Initialize()
        {
            _simTimer = new System.Timers.Timer(200); // 5 lần mỗi giây
            _simTimer.Elapsed += (s, e) => {
                _angle += 0.05;
                // COM1: GPS Speed
                OnDataReceived?.Invoke("COM1", $"$GPVTG,,T,,M,,N,{5 + Math.Sin(_angle) * 3:0.0},K");
                // COM2: Wind Speed
                OnDataReceived?.Invoke("COM2", $"$MWV,120,R,{15 + _random.Next(0, 30):0.0},M,A");
                // COM3: Motion CNTB (Roll, Pitch, Heave)
                OnDataReceived?.Invoke("COM3", $"$CNTB,{Math.Sin(_angle) * 2:0.00},{Math.Cos(_angle) * 1.5:0.00},{Math.Sin(_angle * 2) * 1.0:0.00}");
                // COM4: Heading
                OnDataReceived?.Invoke("COM4", $"$HEHDT,{180 + Math.Sin(_angle / 2) * 10:0.0},T");
            };
            _simTimer.Start();
        }
        public void CloseAll() => _simTimer?.Stop();
    }
}
