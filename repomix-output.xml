<file path="HelideckVer2/Services/DataLogger.cs">
using System;
using System.IO;

namespace HelideckVer2.Services
{
    public class DataLogger
    {
        private string _baseFolder = @"C:\HelideckLog";
        private string _currentFilePath;
        private string _lastFileName = "";

        public DataLogger() { if (!Directory.Exists(_baseFolder)) Directory.CreateDirectory(_baseFolder); }

        public void Log(string data, bool isAlarm)
        {
            DateTime now = DateTime.Now;
            int block = (now.Minute < 30) ? 0 : 30; // Cắt file mỗi phút 00 và 30
            string fileName = $"Log_{now:yyyyMMdd_HH}{block:00}.csv";

            if (fileName != _lastFileName)
            {
                _lastFileName = fileName;
                _currentFilePath = Path.Combine(_baseFolder, fileName);
                if (!File.Exists(_currentFilePath))
                    File.WriteAllText(_currentFilePath, "Time,RawData,AlarmStatus\n");
            }

            try
            {
                string status = isAlarm ? "ALARM" : "NORMAL";
                File.AppendAllText(_currentFilePath, $"{now:HH:mm:ss.fff},{data},{status}\n");
            }
            catch { }
        }
    }
}
